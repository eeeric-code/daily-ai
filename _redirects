# Cloudflare Pages _redirects config
# Make /example/* return 404 (used as reference template only, not for public)

/example/*   /404   404

# 2026-07-06 fix: prevent Cloudflare Pages 308 trailing-slash redirect on archive
# /archive.html → /archive (308) → falls back to /index.html (portal) — wrong!
# Force /archive and /archive/ to serve archive.html content directly.
/archive      /archive.html  200
/archive/     /archive.html  200