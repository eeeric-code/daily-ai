# Cloudflare Pages _headers config
# Block /example/* from public access (used as reference template only)

/example/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=0, no-store

/example/*
  Content-Security-Policy: default-src 'none'

# Block other internal files

/favicon.ico
  Cache-Control: public, max-age=86400
